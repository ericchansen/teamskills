DB_USER=postgres
DB_HOST=localhost
DB_NAME=teamskills
DB_PASSWORD=postgres
DB_PORT=5432
PORT=3001

# Agent Service Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/teamskills

# Frontend Configuration
VITE_AGENT_URL=http://localhost:8000

# Microsoft Entra ID Authentication (optional)
# Register an app at https://portal.azure.com > Microsoft Entra ID > App registrations
# Backend settings:
AZURE_AD_CLIENT_ID=your-app-client-id
AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_SECRET=your-client-secret  # Required for OBO flow (SharePoint sync)

# SharePoint Sync (OBO Flow)
# When AZURE_AD_CLIENT_SECRET is set, the app can sync with the SharePoint
# "Skills Matrix MVP" list using the On-Behalf-Of (OBO) OAuth2 flow.
# This exchanges the user's API token for a Graph token with Sites.ReadWrite.All.
# Requires tenant admin consent for the app's Graph permissions.

# Frontend settings (same values, different prefix):
VITE_AZURE_AD_CLIENT_ID=your-app-client-id
VITE_AZURE_AD_TENANT_ID=your-tenant-id
